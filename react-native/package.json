{
  "name": "@digia-engage/core",
  "version": "2.0.0",
  "description": "React Native bridge for Digia Engage – renders native Android Compose UI inside React Native apps",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "*.podspec",
    "react-native.config.js",
    "!lib/typescript/example",
    "!android/.gradle",
    "!android/build",
    "!android/example",
    "!ios/build",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{js,ts,tsx}\"",
    "build": "bob build",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "digia",
    "engage",
    "compose",
    "android",
    "native"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Digia-Technology-Private-Limited/digia_engage.git",
    "directory": "react-native"
  },
  "author": "Digia Technology Private Limited",
  "license": "MIT",
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.2",
    "react-native-uuid": "^2.0.3"
  },
  "peerDependencies": {
    "@floating-ui/core": "^1.0.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-svg": ">=13.0.0"
  },
  "devDependencies": {
    "@edwardloopez/react-native-coachmark": "^0.5.3",
    "@floating-ui/core": "^1.7.5",
    "@react-native/eslint-config": "^0.73.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "eslint": "^8.51.0",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "react-native-builder-bob": "^0.23.0",
    "react-native-reanimated": "^3.19.3",
    "react-native-svg": "^15.15.1",
    "typescript": "^5.2.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "DigiaEngageSpec",
    "type": "modules",
    "jsSrcsDir": "./src",
    "android": {
      "javaPackageName": "com.digia.engage.rn"
    }
  }
}
